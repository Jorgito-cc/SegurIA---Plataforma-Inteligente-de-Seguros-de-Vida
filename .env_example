frontend_react/
│
├── src/
│   │
│   ├── domain/                 # 🟢 CAPA 1: ENTIDADES
│   │   └── models/             # Clases o interfaces de tus datos (ej. Vehiculo.js, Incidente.js)
│   │
│   ├── application/            # 🟡 CAPA 2: LÓGICA Y ESTADO
│   │   ├── hooks/              # Custom Hooks para tu lógica de negocio (ej. useIncidentes.js)
│   │   ├── context/            # Estado global (React Context o Redux) para guardar sesión
│   │   └── use_cases/          # Funciones puras de negocio (si las hubiera en el cliente)
│   │
│   ├── infrastructure/         # 🔵 CAPA 3: ADAPTADORES (Comunicación con el exterior)
│   │   ├── api/                # Configuración de Axios o Fetch (ej. apiClient.js)
│   │   └── repositories/       
│   │
│   ├── presentation/           # 🔴 CAPA 4: FRAMEWORK WEB (UI de React)
│   │   ├── components/         # Piezas reutilizables (Botones, Tarjetas, Modales)
│   │   ├── pages/              # Vistas completas 
│   │   └── router/             # <--- AQUÍ VA REACT ROUTER (Tus rutas visuales de la web)
│   │
│   ├── App.jsx                 # Componente raíz donde inyectas contextos y el router
│   └── main.jsx                # Punto de entrada de React (donde se monta en el DOM)
│
├── package.json                # 📦 REEMPLAZA a requirements.txt (Aquí van dependencias como react-router, tailwind)
├── vite.config.js              # Configuración del empaquetador (si iniciaste con Vite)
└── .env                        # Variables de entorno para el front (ej. VITE_API_URL=http://localhost:8000)